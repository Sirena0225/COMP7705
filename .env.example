# ============================================================
# 港股舆情分析系统 - 环境变量配置
# 复制此文件为 .env 并填入实际的API密钥
# ============================================================

# -------- LLM API 配置 --------
LLM_API_KEY=sk-xxxxx-your-deepseek-api-key-xxxxx

# 选择模型
# 选项: deepseek-chat, gpt-4o-mini, gpt-4o, gpt-3.5-turbo
LLM_MODEL=deepseek-chat

# -------- OpenAI API 配置 (备选) --------
OPENAI_API_KEY=sk-xxxxx-your-openai-api-key-xxxxx
# 可选：代理或兼容 API 地址（如国内中转）
# OPENAI_BASE_URL=https://api.openai.com/v1

# 嵌入后端: dashscope（默认，阿里云百炼）| openai | local | auto
EMBEDDING_BACKEND=dashscope
# 百炼 Embedding 模型与向量维度（text-embedding-v3/v4 支持 dimensions）
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024
# 地域：intl（新加坡，默认）| cn（北京）；也可直接指定 DASHSCOPE_BASE_URL
DASHSCOPE_REGION=intl
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# -------- 阿里云通义 API 配置 (备选) --------
DASHSCOPE_API_KEY=sk-xxxxx-your-dashscope-api-key-xxxxx

# -------- 向量数据库配置 --------
# ChromaDB 持久化目录
CHROMA_DB_PATH=./data/chroma_db

# -------- 数据库配置 --------
# SQLite 数据库路径 (用于指标追踪)
METRICS_DB_PATH=./data/metrics.db

# -------- 日志配置 --------
LOG_LEVEL=INFO
LOG_FILE=./logs/analysis.log

# -------- 性能配置 --------
# API 调用超时时间 (秒)
API_TIMEOUT=30

# API 重试次数
API_RETRY_ATTEMPTS=3

# LLM 模型的温度参数 (0-1, 越低越确定性)
LLM_TEMPERATURE=0.1

# LLM 模型的 max_tokens
LLM_MAX_TOKENS=1500

# -------- 采样配置 --------
# 数据采样率 (0-1)
SAMPLING_RATE=0.1

# 采样策略 (UNIFORM, STRATIFIED, ADAPTIVE, RISK_AWARE)
SAMPLING_STRATEGY=STRATIFIED

# -------- 评估配置 --------
# 准确率阈值
ACCURACY_MIN=0.85

# 延迟阈值 (毫秒)
LATENCY_MAX_MS=1000

# 一致性阈值
CONSISTENCY_MIN=0.80

# 评估间隔 (秒)
EVALUATION_INTERVAL_SECONDS=300

# 评估批大小
EVALUATION_BATCH_SIZE=100

# -------- 代理配置 (如果需要) --------
# HTTP 代理
HTTP_PROXY=
HTTPS_PROXY=

# -------- 调试配置 --------
# 是否启用调试模式
DEBUG=false

# 是否保存原始 API 响应
SAVE_RAW_RESPONSES=false
